#!/usr/bin/expect -f

set timeout 30

spawn bash -c "cd /Users/sean/xiaoxin-news && export PATH=\"/Users/sean/.workbuddy/binaries/node/versions/22.12.0/bin:\$PATH\" && npx vercel login"

expect "? Log in to Vercel"
send "\r"

expect "Waiting for authentication"

puts "\n========================================"
puts "请在浏览器中打开以下链接并授权："
puts "https://vercel.com/oauth/device"
puts "========================================\n"

interact
